# ===== REQUIRED =====
JWT_SECRET=change-me-to-a-random-64-char-string
JWT_REFRESH_SECRET=change-me-to-another-random-64-char-string

# ===== SERVER =====
NODE_ENV=production
PORT=3001
CORS_ORIGIN=*

# ===== DATABASE =====
# SQLite (default): leave DB_PATH commented for ./chess3d.db
# PostgreSQL (Render): set DATABASE_URL
# DB_PATH=./chess3d.db

# ===== OPTIONAL =====
# LOG_LEVEL=info
# RATE_LIMIT_MAX=100
# MOVE_RATE_LIMIT_MAX=30
