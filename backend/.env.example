# Server
PORT=3001
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=chess3d
DB_USER=postgres
DB_PASSWORD=postgres

# JWT
JWT_SECRET=change-this-to-a-random-secret-string-at-least-64-chars
JWT_REFRESH_SECRET=change-this-to-another-random-secret-string
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
